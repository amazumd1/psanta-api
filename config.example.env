# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Gemini AI Configuration
GEMINI_API_KEY=you-ai-key

# Retail receipts auto scheduler
RETAIL_AUTO_SCHEDULER_ENABLED=true
RETAIL_AUTO_SCHEDULER_TICK_MINUTES=5
RETAIL_AUTO_RECENT_EVERY_MINUTES=5
RETAIL_AUTO_SCHEDULER_BATCH_LIMIT=25
RETAIL_AUTO_SCHEDULER_RUN_ON_START=true
RETAIL_AUTO_SCHEDULER_SECRET=