# Retail receipts auto scheduler
RETAIL_AUTO_SCHEDULER_ENABLED=true
RETAIL_AUTO_SCHEDULER_TICK_MINUTES=5
RETAIL_AUTO_RECENT_EVERY_MINUTES=5
RETAIL_AUTO_SCHEDULER_BATCH_LIMIT=25
RETAIL_AUTO_SCHEDULER_RUN_ON_START=true
RETAIL_AUTO_SCHEDULER_SECRET=

# =========================================================
# Market Rate Search Suggestions
# Backend only. Do not put these in VITE frontend env.
# =========================================================

# Recommended for recurring free monthly search:
MARKET_SEARCH_PROVIDER=tavily

# Use auto to try Tavily -> Serper -> Google CSE:
# MARKET_SEARCH_PROVIDER=auto

MARKET_SEARCH_QUERY_LIMIT=3
MARKET_SEARCH_RESULTS_PER_QUERY=5

TAVILY_API_KEY=
TAVILY_MARKET_QUERY_LIMIT=3
TAVILY_RESULTS_PER_QUERY=5
TAVILY_SEARCH_DEPTH=basic

FIRECRAWL_API_KEY=
FIRECRAWL_ENABLED=true
FIRECRAWL_TOP_PAGES_PER_SERVICE=2
FIRECRAWL_TIMEOUT_MS=30000

# Optional fallback/manual providers
SERPER_API_KEY=
SERPER_DEV_API_KEY=
SERPER_MARKET_QUERY_LIMIT=3
SERPER_RESULTS_PER_QUERY=5

GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
GOOGLE_CSE_MARKET_QUERY_LIMIT=3
GOOGLE_CSE_RESULTS_PER_QUERY=5

# StartHere AI cache layer. Stores sanitized pattern templates only, not raw chat text.
START_HERE_AI_CACHE_ENABLED=true
START_HERE_AI_CACHE_TTL_MS=604800000
START_HERE_AI_CACHE_MAX_RECORDS=500
START_HERE_AI_CACHE_MIN_CONFIDENCE=0.65
# Optional custom cache file path. Default: services/api/.runtime/start-here-ai-cache.json
# START_HERE_AI_CACHE_FILE=