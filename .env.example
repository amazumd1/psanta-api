# Use auto to try Tavily -> Serper -> Google CSE:
# MARKET_SEARCH_PROVIDER=auto

MARKET_SEARCH_QUERY_LIMIT=3
MARKET_SEARCH_RESULTS_PER_QUERY=5

TAVILY_API_KEY=
TAVILY_MARKET_QUERY_LIMIT=3
TAVILY_RESULTS_PER_QUERY=5
TAVILY_SEARCH_DEPTH=basic

FIRECRAWL_API_KEY=
FIRECRAWL_ENABLED=true
FIRECRAWL_TOP_PAGES_PER_SERVICE=2
FIRECRAWL_TIMEOUT_MS=30000

